{
  "name": "paratranz-string-reviewer",
  "version": "1.0.0",
  "description": "CLI tool for reviewing Paratranz translation strings with LLMs",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "reviewer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "run": "tsx src/cli.ts run"
  },
  "keywords": [
    "paratranz",
    "llm",
    "review"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "openai": "^6.33.0",
    "undici": "^7.24.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
